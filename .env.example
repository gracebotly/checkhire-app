# ════════════════════════════════════════════════════════════════
# CheckHire — Environment Variables
# ════════════════════════════════════════════════════════════════

# ── Slack Admin Notifications ──
# Create an Incoming Webhook at https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=

# ── Cron Authentication ──
# Used by /api/cron/* routes to verify scheduled job calls.
# Generate a strong random string (e.g. `openssl rand -hex 32`).
# This MUST be set in BOTH Vercel env vars AND GitHub Actions secrets.
# See docs/CRON.md for setup instructions.
CRON_SECRET=
